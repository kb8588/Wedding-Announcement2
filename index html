    </div>

    <div class="eyebrow">An Announcement from</div>

    <div class="names">
      Kerbie
      <span class="amp">&</span>
      Cory
    </div>

    <div class="tagline">The Wedding Countdown Begins...</div>

    <div class="divider">
      <div class="divider-line"></div>
      <div class="divider-dot"></div>
      <div class="divider-center">✦</div>
      <div class="divider-dot"></div>
      <div class="divider-line right"></div>
    </div>

    <div class="details">
      <div class="detail-item">
        <div class="detail-label">Date</div>
        <div class="detail-value">September 23rd, 2026</div>
      </div>
      <div class="detail-item">
        <div class="detail-label">Location</div>
        <div class="detail-value">Isle of Skye<small>Scotland, UK</small></div>
