    <circle cx="160" cy="155" r="4" fill="#9b7a9e" opacity="0.4"/>
  </svg>

  <svg class="botanical botanical-br" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M10 10 Q30 80 80 120 Q120 160 190 190" stroke="#9b7a9e" stroke-width="1" fill="none"/>
    <path d="M10 10 Q40 50 60 100 Q75 140 110 170" stroke="#6b7c63" stroke-width="0.8" fill="none"/>
    <ellipse cx="80" cy="120" rx="11" ry="5" transform="rotate(45 80 120)" fill="#9b7a9e" opacity="0.5"/>
  </svg>

  <div class="content">

    <div class="top-ornament">
      <div class="rule"></div>
