<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kerbie & Cory — We're Getting Married</title>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@200;300;400&family=Raleway:wght@100;200;300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --heather: #6b4e6e;
    --heather-light: #9b7a9e;
    --mist: #c2bfc8;
    --dark: #1a1720;
    --deep: #231e2b;
    --peat: #2e2838;
    --linen: #e8e2d9;
    --cream: #f2ede6;
    --moss: #4a5c42;
    --moss-light: #6b7c63;
    --fog: rgba(194,191,200,0.12);
  }

  html, body {
    width: 100%;
    min-height: 100vh;
    background: var(--dark);
    font-family: 'Jost', sans-serif;
    color: var(--linen);
    -webkit-font-smoothing: antialiased;
  }

  .page {
    max-width: 600px;
    margin: 0 auto;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    background: linear-gradient(175deg, #1a1720 0%, #231e2b 40%, #1e1c28 70%, #191620 100%);
  }

  /* Atmospheric layers */
  .mist-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .mist-layer::before {
    content: '';
    position: absolute;
    top: 0; left: -20%; right: -20%;
    height: 55%;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(107,78,110,0.18) 0%, transparent 70%),
                radial-gradient(ellipse 60% 40% at 30% 20%, rgba(74,92,66,0.10) 0%, transparent 60%),
                radial-gradient(ellipse 50% 30% at 70% 10%, rgba(194,191,200,0.06) 0%, transparent 50%);
  }

  .mist-layer::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(to top, rgba(107,78,110,0.07) 0%, transparent 100%);
  }

  /* Botanical SVG elements */
  .botanical {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    opacity: 0.22;
  }
  .botanical-tl { top: -10px; left: -15px; width: 180px; transform: rotate(-15deg); }
  .botanical-tr { top: -5px; right: -20px; width: 160px; transform: rotate(165deg) scaleX(-1); opacity: 0.18; }
  .botanical-bl { bottom: 60px; left: -10px; width: 140px; transform: rotate(20deg); opacity: 0.15; }
  .botanical-br { bottom: 40px; right: -15px; width: 150px; transform: rotate(-160deg); opacity: 0.13; }

  /* Content */
  .content {
    position: relative;
    z-index: 2;
    padding: 52px 36px 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Top rule */
  .top-ornament {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
    animation: fadeUp 0.8s ease both;
  }
  .rule {
    height: 1px;
    width: 50px;
    background: linear-gradient(to right, transparent, var(--heather-light));
  }
  .rule.right { background: linear-gradient(to left, transparent, var(--heather-light)); }
  .diamond {
    width: 5px; height: 5px;
    background: var(--heather-light);
    transform: rotate(45deg);
  }

  /* Eyebrow */
  .eyebrow {
    font-family: 'Jost', sans-serif;
    font-weight: 200;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--heather-light);
    margin-bottom: 20px;
    animation: fadeUp 0.8s 0.1s ease both;
  }

  /* Names */
  .names {
    font-family: 'Great Vibes', cursive;
    font-weight: 400;
    font-size: clamp(52px, 14vw, 80px);
    line-height: 1.05;
    color: var(--cream);
    letter-spacing: 0.02em;
    margin-bottom: 6px;
    animation: fadeUp 0.9s 0.2s ease both;
  }
  .names .amp {
    color: var(--heather-light);
    font-size: 0.75em;
    display: block;
    margin: -6px 0;
  }

  /* Tagline */
  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 17px;
    color: var(--mist);
    letter-spacing: 0.06em;
    margin-bottom: 28px;
    animation: fadeUp 0.9s 0.3s ease both;
  }

  /* Divider with thistle motif */
  .divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
    animation: fadeUp 0.8s 0.35s ease both;
  }
  .divider-line {
    height: 1px;
    width: 70px;
    background: linear-gradient(to right, transparent, rgba(194,191,200,0.3));
  }
  .divider-line.right { background: linear-gradient(to left, transparent, rgba(194,191,200,0.3)); }
  .divider-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: rgba(194,191,200,0.4);
  }
  .divider-center {
    font-size: 14px;
    color: rgba(194,191,200,0.5);
    letter-spacing: 0.1em;
  }

  /* Details block */
  .details {
    display: flex;
    gap: 0;
    margin-bottom: 32px;
    animation: fadeUp 0.9s 0.4s ease both;
    border: 1px solid rgba(107,78,110,0.25);
    background: rgba(35,30,43,0.6);
  }

  .detail-item {
    flex: 1;
    padding: 16px 20px;
    position: relative;
  }
  .detail-item + .detail-item::before {
    content: '';
    position: absolute;
    left: 0; top: 20%; bottom: 20%;
    width: 1px;
    background: rgba(107,78,110,0.25);
  }
  .detail-label {
    font-family: 'Jost', sans-serif;
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--heather-light);
    margin-bottom: 5px;
  }
  .detail-value {
    font-family: 'Raleway', sans-serif;
    font-weight: 200;
    font-size: 16px;
    color: var(--cream);
    letter-spacing: 0.08em;
    line-height: 1.3;
  }
  .detail-value small {
    display: block;
    font-size: 12px;
    color: var(--mist);
    font-weight: 200;
    margin-top: 1px;
    letter-spacing: 0.06em;
  }

  /* Body copy */
  .body-copy {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 14.5px;
    line-height: 1.85;
    color: var(--mist);
    text-align: left;
    margin-bottom: 28px;
    animation: fadeUp 0.9s 0.5s ease both;
    padding: 0 2px;
  }
  .body-copy p + p { margin-top: 14px; }
  .body-copy strong {
    color: var(--cream);
    font-weight: 400;
  }

  /* CTA block */
  .cta-block {
    width: 100%;
    border: 1px solid rgba(107,78,110,0.4);
    background: linear-gradient(135deg, rgba(107,78,110,0.12) 0%, rgba(35,30,43,0.7) 100%);
    padding: 24px 24px 22px;
    margin-bottom: 36px;
    animation: fadeUp 0.9s 0.6s ease both;
    position: relative;
    overflow: hidden;
  }
  .cta-block::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--heather), transparent);
  }
  .cta-label {
    font-family: 'Jost', sans-serif;
    font-weight: 200;
    font-size: 9.5px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--heather-light);
    margin-bottom: 10px;
  }
  .cta-heading {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 22px;
    font-weight: 300;
    color: var(--cream);
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .cta-body {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 13.5px;
    line-height: 1.8;
    color: var(--mist);
  }
  .cta-body strong { color: var(--cream); font-weight: 400; }

  /* Deadline pill */
  .deadline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 8px 16px;
    border: 1px solid rgba(107,78,110,0.5);
    background: rgba(107,78,110,0.15);
  }
  .deadline-label {
    font-family: 'Jost', sans-serif;
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--heather-light);
  }
  .deadline-date {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    color: var(--cream);
    letter-spacing: 0.05em;
  }

  /* Closing */
  .closing {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 18px;
    font-weight: 300;
    color: var(--mist);
    margin-bottom: 6px;
    animation: fadeUp 0.9s 0.7s ease both;
  }
  .closing-names {
    font-family: 'Great Vibes', cursive;
    font-size: 36px;
    font-weight: 400;
    color: var(--cream);
    letter-spacing: 0.02em;
    animation: fadeUp 0.9s 0.75s ease both;
    margin-bottom: 32px;
  }

  /* Bottom rule */
  .bottom-ornament {
    display: flex;
    align-items: center;
    gap: 12px;
    animation: fadeUp 0.8s 0.8s ease both;
  }
  .bottom-ornament .rule { width: 40px; }

  /* Secondary blocks */
  .secondary-block, .zola-block {
    width: 100%;
    border: 1px solid rgba(107,78,110,0.2);
    background: rgba(35,30,43,0.5);
    padding: 20px 22px;
    margin-bottom: 20px;
    animation: fadeUp 0.9s 0.65s ease both;
    text-align: left;
  }
  .zola-block { animation-delay: 0.7s; }
  .secondary-label {
    font-family: 'Jost', sans-serif;
    font-weight: 200;
    font-size: 9.5px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--heather-light);
    margin-bottom: 10px;
  }
  .secondary-body {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 13.5px;
    line-height: 1.8;
    color: var(--mist);
    margin-bottom: 12px;
  }
  .secondary-body strong { color: var(--cream); font-weight: 400; }
  .address-block {
    font-family: 'Raleway', sans-serif;
    font-weight: 200;
    font-size: 13px;
    letter-spacing: 0.05em;
    line-height: 1.9;
    color: var(--cream);
    border-left: 2px solid rgba(107,78,110,0.4);
    padding-left: 14px;
    margin-top: 4px;
  }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .content { padding: 40px 24px 48px; }
    .details { flex-direction: column; }
    .detail-item + .detail-item::before {
      top: 0; left: 15%; right: 15%; bottom: auto;
      width: auto; height: 1px;
    }
  }
</style>
</head>
<body>
<div class="page">
  <div class="mist-layer"></div>

  <!-- Botanical corners -->
  <svg class="botanical botanical-tl" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
