  <svg class="botanical botanical-tr" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M10 190 Q30 120 80 80 Q120 40 190 10" stroke="#9b7a9e" stroke-width="1" fill="none"/>
    <path d="M10 190 Q40 150 60 100 Q75 60 110 30" stroke="#6b7c63" stroke-width="0.8" fill="none"/>
