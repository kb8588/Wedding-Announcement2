    <div class="closing">With so much love,</div>
    <div class="closing-names">Kerbie & Cory</div>

    <div class="bottom-ornament">
      <div class="rule"></div>
      <div class="diamond"></div>
      <div class="rule right"></div>
    </div>

  </div>
</div>
</body>
</html>
